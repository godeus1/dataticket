<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f3f4f6; margin: 0; padding: 0; }
      .body { color: #374151; line-height: 1.6; font-size: 14px; }
      .body h2 { font-size: 18px; color: #111827; margin-top: 0; margin-bottom: 12px; }
      .body p { margin: 0 0 12px; }
      /* Tabelas de dados dentro do corpo dos e-mails (não afeta a estrutura) */
      .body table { width: 100%; border-collapse: collapse; margin: 16px 0; }
      .body th, .body td { text-align: left; padding: 9px 12px; font-size: 14px; border-bottom: 1px solid #e5e7eb; }
      .body th { background: #f0f7ff; font-weight: 600; color: #374151; }
      .body a { color: #2383e2; }
      /* Botão depois de .body a para vencer a especificidade e manter o texto branco */
      .body a.btn { display: inline-block; margin-top: 24px; padding: 12px 24px; background: #2383e2; color: #ffffff !important; text-decoration: none; border-radius: 8px; font-weight: 600; }
    </style>
  </head>
  <body style="margin:0;padding:0;background:#f3f4f6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background:#f3f4f6;padding:40px 20px;">
      <tr>
        <td align="center">
          <table width="100%" cellpadding="0" cellspacing="0" style="max-width:520px;">

            <!-- Header -->
            <tr>
              <td style="background:#2383e2;padding:28px 32px;border-radius:12px 12px 0 0;">
                <table width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="border:none;">
                      <span style="font-size:28px;vertical-align:middle;">&#127919;</span>
                      <span style="color:#ffffff;font-size:20px;font-weight:800;vertical-align:middle;margin-left:10px;">DataTicket</span>
                    </td>
                    <td align="right" style="border:none;">
                      <span style="color:#bfdbfe;font-size:12px;">Helpdesk</span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td class="body" style="background:#ffffff;padding:36px 32px;border:1px solid #e5e7eb;border-top:none;border-radius:0 0 12px 12px;">
                <%= yield %>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding:20px 0;text-align:center;">
                <p style="margin:0;font-size:11px;color:#9ca3af;">
                  &copy; <%= Time.current.year %> DataTry Tecnologia e Neg&oacute;cios &middot; DataTicket Helpdesk
                </p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
