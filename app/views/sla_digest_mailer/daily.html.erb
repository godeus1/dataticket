<h2>Resumo SLA — <%= Date.current.strftime("%d/%m/%Y") %></h2>
<p>Olá, <strong><%= @user.first_name %></strong>.</p>

<% if @expired.any? %>
<h3 style="color:#dc2626;">Tickets com SLA vencido (<%= @expired.size %>)</h3>
<table>
  <tr><th>ID</th><th>Título</th><th>Status</th><th>Prazo</th></tr>
  <% @expired.each do |ticket| %>
  <tr>
    <td><%= ticket.id %></td>
    <td><%= ticket.title %></td>
    <td><%= ticket.status %></td>
    <td><%= ticket.deadline&.strftime("%d/%m/%Y %H:%M") %></td>
  </tr>
  <% end %>
</table>
<% end %>

<% if @expiring_today.any? %>
<h3 style="color:#d97706;">Tickets com SLA vencendo hoje (<%= @expiring_today.size %>)</h3>
<table>
  <tr><th>ID</th><th>Título</th><th>Status</th><th>Prazo</th></tr>
  <% @expiring_today.each do |ticket| %>
  <tr>
    <td><%= ticket.id %></td>
    <td><%= ticket.title %></td>
    <td><%= ticket.status %></td>
    <td><%= ticket.deadline&.strftime("%d/%m/%Y %H:%M") %></td>
  </tr>
  <% end %>
</table>
<% end %>

<% if @expired.empty? && @expiring_today.empty? %>
<p style="color:#16a34a;">Nenhum ticket com SLA crítico no momento.</p>
<% end %>

<a href="<%= @url %>" class="btn">Ver todos os tickets</a>
