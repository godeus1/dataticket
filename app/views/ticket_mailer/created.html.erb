<h2>Seu ticket foi criado com sucesso!</h2>
<p>Olá, <strong><%= @user.first_name %></strong>.</p>
<p>Recebemos seu ticket e nossa equipe irá analisá-lo em breve.</p>
<table>
  <tr><th>ID</th><td><%= @ticket.id %></td></tr>
  <tr><th>Título</th><td><%= @ticket.title %></td></tr>
  <tr><th>Status</th><td><%= @ticket.status %></td></tr>
  <tr><th>Criado em</th><td><%= @ticket.created_at.strftime("%d/%m/%Y às %H:%M") %></td></tr>
</table>
<a href="<%= @url %>" class="btn" style="color:#ffffff;">Ver Ticket</a>
