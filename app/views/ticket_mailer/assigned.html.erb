<h2>Ticket atribuido a voce</h2>
<p>Ola, <strong><%= @user.first_name %></strong>.</p>
<p>O ticket <strong><%= @ticket.id %></strong> foi atribuido a voce.</p>
<table>
  <tr><th>ID</th><td><%= @ticket.id %></td></tr>
  <tr><th>Título</th><td><%= @ticket.title %></td></tr>
  <tr><th>Status</th><td><%= @ticket.status %></td></tr>
  <% if @ticket.priority %><tr><th>Prioridade</th><td><%= @ticket.priority.name %></td></tr><% end %>
  <% if @ticket.deadline %><tr><th>Prazo</th><td><%= @ticket.deadline.strftime("%d/%m/%Y às %H:%M") %></td></tr><% end %>
</table>
<a href="<%= @url %>" class="btn">Ver Ticket</a>
