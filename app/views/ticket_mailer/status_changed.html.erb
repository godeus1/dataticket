<h2>Status do ticket atualizado</h2>
<p>Ola, <strong><%= @user.first_name %></strong>.</p>
<p>O status do ticket <strong><%= @ticket.id %></strong> foi atualizado.</p>
<table>
  <tr><th>ID</th><td><%= @ticket.id %></td></tr>
  <tr><th>Título</th><td><%= @ticket.title %></td></tr>
  <tr><th>Status anterior</th><td><%= @old_status %></td></tr>
  <tr><th>Novo status</th><td><%= @new_status %></td></tr>
</table>
<a href="<%= @url %>" class="btn">Ver Ticket</a>
