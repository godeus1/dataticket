# ─────────────────────────────────────────────────────────────────
#  DataTicket API — variáveis de ambiente
#  Copie para .env e preencha os valores antes de rodar localmente.
#  NUNCA commite o arquivo .env com valores reais.
# ─────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────
# Em produção o Railway injeta DATABASE_URL automaticamente.
# Em desenvolvimento, use as vars individuais abaixo.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/dataticket_api_development

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# ── Rails ─────────────────────────────────────────────────────────
RAILS_ENV=development
RAILS_MAX_THREADS=5
RAILS_MASTER_KEY=          # obtido de config/master.key (nunca commitar)

# ── Autenticação JWT ──────────────────────────────────────────────
# Gere com: rails secret | head -c 64
DEVISE_JWT_SECRET_KEY=seu-segredo-jwt-aqui-com-pelo-menos-64-chars

# ── Seeds ─────────────────────────────────────────────────────────
SEED_ADMIN_PASSWORD=SenhaAdminForte123!

# ── CORS / Frontend ───────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
FRONTEND_URL=http://localhost:5173
APP_HOST=localhost          # domínio público em produção (ex: api.dataticket.app)

# ── SMTP (e-mail) ─────────────────────────────────────────────────
# Exemplos testados: smtp.gmail.com, smtp.office365.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app   # para Gmail: use "Senha de app" nas config de conta

# ── Monitoramento ─────────────────────────────────────────────────
SENTRY_DSN=                  # obtenha em sentry.io → Settings → Projects → DSN

# ── Background jobs (Solid Queue — sem Redis) ─────────────────────
# SOLID_QUEUE_IN_PUMA=true  → jobs rodam dentro do Puma (desenvolvimento/single-server)
# Em produção com Railway, o worker é um serviço separado (Procfile: worker)
SOLID_QUEUE_IN_PUMA=true
JOB_CONCURRENCY=1

# ── Armazenamento de arquivos ─────────────────────────────────────
# Padrão: :local  |  Em produção: :amazon
# STORAGE=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET=dataticket-uploads
