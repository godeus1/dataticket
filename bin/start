#!/bin/bash
# bin/start — ponto de entrada do processo web no Railway / Docker
# Responsável por: aplicar migrations pendentes e iniciar o servidor Puma.
#
# Separar a migração do startCommand evita o problema de dupla execução
# que ocorria quando o Docker ENTRYPOINT detectava "rails server" no $* e
# rodava db:prepare, e em seguida o sh -c "... && rails server" também
# rodava db:prepare, causando conflito de advisory lock em deploys rolling.
#
# SKIP_MIGRATIONS=true — pula o db:prepare (útil para emergências onde a
# migration está travando o boot; remova a variável após resolver o problema).

set -e

if [ "${SKIP_MIGRATIONS}" = "true" ]; then
  echo "==> [$(date -u '+%Y-%m-%dT%H:%M:%SZ')] SKIP_MIGRATIONS=true — pulando db:prepare."
else
  echo "==> [$(date -u '+%Y-%m-%dT%H:%M:%SZ')] Applying pending migrations (db:prepare)..."
  # Timeout de 60s: se o banco estiver com advisory lock travado, não derruba o processo —
  # apenas avisa e continua o boot. A aplicação sobe e o healthcheck passa.
  if ! timeout 60 bundle exec rails db:prepare; then
    echo "==> [$(date -u '+%Y-%m-%dT%H:%M:%SZ')] AVISO: db:prepare falhou ou travou (timeout 60s). Continuando o boot sem migrations."
  fi
fi

echo "==> [$(date -u '+%Y-%m-%dT%H:%M:%SZ')] Starting Puma..."
exec bundle exec rails server -b 0.0.0.0
